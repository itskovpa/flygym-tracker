__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.pytest_cache/
# large / machine-specific artifacts
data/
output/
*.avi
*.mp4
*.bmp
# large, regenerable QA overlay (the json + mask ARE committed)
calib/overlay_*.png
# keep calibration bundle + committed sample docs
!docs/*.png
calib_faces/overlay_*.png

# THIS MACHINE'S OWN SETTINGS. `config/x.local.yaml` layers on top of the shipped `config/x.yaml`
# and is what the app writes to, so one rig's tuning never lands in the template a fresh clone
# gets. Ignored on purpose: these are a machine's values, not the project's.
config/*.local.yaml

# Installer build output. The bundle is ~291 MB and the installer ~82 MB; they are release
# artifacts, rebuilt from source by `python packaging/build_installer.py`.
packaging/dist/
packaging/build/

# Diagnostic output written at runtime by `diagnostics.py` (session logs) and `debug_run.py`
# (the crash-watch harness). These are a record of one machine's runs, regenerated every launch --
# never the project's, exactly like the ignored gui_state/output above.
logs/
packaging/debug_crash*.log

# `python -m build` output. It is a full copy of src/, and committing it means two versions of
# every module in the repo -- the stale one wins in a grep and nobody notices.
build/
*.egg-info/
